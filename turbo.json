{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"deploy": {
			"dependsOn": ["^deploy"]
		},
		"docker:build": {
			"dependsOn": ["^docker:build"]
		},
		"docker:push": {
			"dependsOn": ["^docker:push"]
		},
		"start": {
			"dependsOn": ["^start"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
