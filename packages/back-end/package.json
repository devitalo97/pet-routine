{
	"name": "@pack/back-end",
	"version": "1.0.0",
	"description": "back end logics of pet routine app",
	"keywords": [
		"back-end"
	],
	"imports": {
		"#/*": "./src/*"
	},
	"license": "ISC",
	"author": "Ítalo de Souza",
	"type": "module",
	"devDependencies": {
		"@pack/biome": "workspace:*",
		"@pack/typescript": "workspace:*",
		"drizzle-kit": "^0.31.10"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	},
	"scripts": {
		"dev": "bun --watch run src/index.ts",
		"build": "bun build src/index.ts --target=bun --outdir dist && tsc",
		"start": "bun run dist/index.js",
		"db:generate": "bunx --bun drizzle-kit generate --config ./src/infrastructure/db/drizzle.config.ts",
		"db:migrate": "bunx --bun drizzle-kit migrate --config ./src/infrastructure/db/drizzle.config.ts",
		"db:push": "bunx --bun drizzle-kit push --config ./src/infrastructure/db/drizzle.config.ts"
	},
	"module": "index.ts",
	"private": true,
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	}
}
