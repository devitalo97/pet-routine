{
	"extends": "@pack/typescript/bun.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"declaration": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"paths": {
			"#/*": ["./src/*"]
		},
		"plugins": [
			{
				"name": "tsc-alias"
			}
		]
	},
	"include": ["src"],
	"exclude": ["dist"]
}
